# === Expo 客户端（可进入版本库的示例，勿填真实密钥）===
# Supabase Edge Function「发送验证码」完整 URL
# 若使用 MCP / Dashboard 创建的 OneRss 项目，ref 为 xwjqiuychlokthyocybf：
EXPO_PUBLIC_AUTH_SEND_CODE_URL=https://xwjqiuychlokthyocybf.supabase.co/functions/v1/send-email-code
EXPO_PUBLIC_AUTH_VERIFY_CODE_URL=https://xwjqiuychlokthyocybf.supabase.co/functions/v1/verify-email-code
EXPO_PUBLIC_AUTH_REGISTER_URL=https://xwjqiuychlokthyocybf.supabase.co/functions/v1/register-email-password
# 调用需携带 Supabase anon key（与 Dashboard - Project API 一致）
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# === Supabase Edge / 服务端密钥（仅在 Supabase Dashboard「Secrets」配置，禁止提交）===
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# OTP_PEPPER=
# REGISTRATION_TICKET_SECRET=（可选；未配置时默认复用 OTP_PEPPER）
# SUPABASE_URL=（Edge 默认注入，一般无需手写）
# SUPABASE_SERVICE_ROLE_KEY=（Edge 默认注入，一般无需手写）
